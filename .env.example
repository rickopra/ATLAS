COMPOSE_PROJECT_NAME=atlas
NODE_ENV=production
TZ=Asia/Jakarta

WEB_PORT=3000
API_PORT=4000
NGINX_PORT=80

POSTGRES_DB=atlas
POSTGRES_USER=atlas_app
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_URL=postgresql://atlas_app:CHANGE_ME_DB_PASSWORD@postgres:5432/atlas?schema=public

REDIS_URL=redis://redis:6379

APP_NAME=ATLAS
APP_URL=https://atlas.yourdomain.com
APP_ORIGIN=https://atlas.yourdomain.com
NEXT_PUBLIC_APP_URL=https://atlas.yourdomain.com
NEXT_PUBLIC_API_URL=https://atlas.yourdomain.com/api

JWT_ACCESS_SECRET=CHANGE_ME_JWT_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET_MIN_32_CHARS
SESSION_COOKIE_SECRET=CHANGE_ME_SESSION_COOKIE_SECRET_MIN_32_CHARS

LOCAL_AUTH_ENABLED=true
LOCAL_SUPERADMIN_EMAIL=admin@yourdomain.com
LOCAL_SUPERADMIN_NAME=Admin
LOCAL_SUPERADMIN_USERNAME=admin
LOCAL_SUPERADMIN_PASSWORD=CHANGE_ME_LOCAL_SUPERADMIN_PASSWORD
ATLAS_STORAGE_DIR=/atlas-data/storage

# Procurement request AI parsing — optional, leave blank to disable
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ATLAS_SCRIPT_PROPERTIES_JSON=

# Google OAuth — set GOOGLE_OAUTH_ENABLED=true and fill in if using Google login
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_HOSTED_DOMAIN=yourdomain.com
GOOGLE_CALLBACK_URL=https://atlas.yourdomain.com/api/auth/google/callback

# Google Workspace Directory Sync — optional
# Requires a GCP service account JSON key placed in secure/ (excluded from git)
GOOGLE_WORKSPACE_DIRECTORY_ENABLED=false
GOOGLE_WORKSPACE_DIRECTORY_PROJECT_ID=your-gcp-project-id
GOOGLE_WORKSPACE_DIRECTORY_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_WORKSPACE_DIRECTORY_DELEGATED_ADMIN_EMAIL=admin@yourdomain.com
GOOGLE_WORKSPACE_DIRECTORY_KEY_FILE=/var/www/ATLAS/secure/google-workspace-directory.json
GOOGLE_WORKSPACE_DIRECTORY_CUSTOMER=my_customer
GOOGLE_WORKSPACE_DIRECTORY_CUSTOM_SCHEMA=ATLAS

DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
